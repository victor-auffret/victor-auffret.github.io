---
const { nom, infos, prix } = Astro.props
const nom_cut = nom.replaceAll(" ", "-")
---

<!-- menu-card -->

 <div class="menu-card">

  <input class="menu-hidden-checkbox" type="checkbox" name={`menu-${nom_cut}`} id={`menu-${nom_cut}`} />
  
  <!-- menu-card-front -->
  <div class="menu-card-front">

   <div class="menu-card-content">

    <article class="menu-card-intitule">
     <h3 class="menu-card-intitule-txt">{nom}</h3>
     <p class="menu-card-intitule-txt">{infos}</p>
    </article>
    
    <aside class="prix">
     <data value={prix}>{prix} €</data>
    </aside>

   </div>
   
  </div>
  <!-- fin menu-card-front -->
  
  <!-- menu-card-back -->
  <div class="menu-card-back">
   
   <!-- menu-card-back-box -->
   <div class="menu-card-back-box">
    <div class="cercle">
     <label for={`menu-${nom_cut}`}>
      <span class="icon"><i class="fa-solid fa-check"></i></span>
     </label>
    </div>
   </div>
   <!-- fin menu-card-back-box -->

  </div>
  <!-- fin menu-card-back -->

 </div>
 <!-- fin menu-card -->

