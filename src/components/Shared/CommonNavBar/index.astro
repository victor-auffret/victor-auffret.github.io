---
import "./index.scss";
const { isMenu } = Astro.props || false;
const slash = isMenu ? "../" : "./"
---

<header class="app-header">
 { isMenu ? (<div class="btn-return">
  <a href="../../index.html">
   <i class="fa-solid fa-arrow-left"></i>
  </a>
  </div>) : null }
 <div class="center">
  <h1 class="big-title">
   <a href={`${slash}index.html`}>
    <img class="logo" src={`${slash}assets/images/logo/ohmyfood.svg`} alt="ohmyfood" />
   </a>
  </h1>
 </div>
</header>