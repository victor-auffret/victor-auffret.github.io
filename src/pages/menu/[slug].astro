---
import Page from '@components/Shared/Page/index.astro';
import CommonNavBar from '@components/Shared/CommonNavBar/index.astro';
import MenuMain from '@components/Menus/MenuMain/index.astro';
import CommonPied from '@components/Shared/CommonPied/index.astro';
import jsondata from '../../data/resto.json';

export async function getStaticPaths() {
 return jsondata.restos.map((resto) => {
  const nom = resto.title
  const slug = resto.slug
  const menu = resto.menu
  return {
   params: { slug },
   props: { nom, menu, slug }
  }
 })
}

const { nom, menu, slug } = Astro.props;
---

<Page title={`menu : ${nom}`}>

  <CommonNavBar isMenu={true} />
  
  <MenuMain nom={nom} menu={menu} slug={slug} />
  
  <CommonPied/>

</Page>
