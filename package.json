{
  "name": "victor-auffret.github.io",
  "version": "1.0.0",
  "description": "",
  "main": "./src/scss/index.scss",
  "type": "module",
  "engines": {
    "node": ">=16"
  },
  "scripts": {
    "dev": "npm run css:watch && npm run html:watch",
    "html:watch": "astro dev",
    "html:build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "css:watch": "npm run build-css -- --watch",
    "css:build": "npm run build-css && npm run build-prefix && npm run build-cleancss",
    "build-css": "node-sass --scss --output-style expanded --source-map true src/scss/index.scss public/css/style.css",
    "build-prefix": "postcss --use autoprefixer --map false --output public/css/style.css public/css/style.css",
    "build-cleancss": "cleancss -o public/css/style.min.css public/css/style.css",
    "rebuild": "npm run clean && npm run css:build",
    "restart": "npm run clean && npm run css:watch",
    "clean": "rimraf public/css/* && rimraf .sass-cache/"
  },
  "dependencies": {
    "astro": "^1.6.15"
  },
  "devDependencies": {
    "autoprefixer": "^10.4.13",
    "clean-css-cli": "^5.6.1",
    "node-sass": "^8.0.0",
    "postcss-cli": "^10.1.0",
    "rimraf": "^3.0.2"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/victor-auffret/victor-auffret.github.io.git"
  },
  "author": "victor-auffret",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/victor-auffret/victor-auffret.github.io/issues"
  },
  "homepage": "https://github.com/victor-auffret/victor-auffret.github.io#readme"
}
