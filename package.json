{
  "name": "victor-auffret.github.io",
  "version": "1.0.0",
  "description": "ohmyfood page OC 03",
  "type": "module",
  "engines": {
    "node": ">=16"
  },
  "scripts": {
    "dev": "npm run watch",
    "watch": "astro dev",
    "build": "",
    "html:build": "astro build",
    "clean": "rimraf docs/* && rimraf .sass-cache/",
    "rebuild": "npm run clean && npm run build",
    "preview": "astro preview",
    "astro": "astro",
    "css:dev": "npm run build-css -- --watch",
    "css:build": "npm run build-css && npm run build-prefix && npm run build-cleancss",
    "build-css": "node-sass --scss --output-style expanded --source-map true src/scss/index.scss docs/assets/css/b-css.css",
    "build-prefix": "postcss --use autoprefixer --map false --output docs/assets/css/b-css.css docs/assets/css/b-css.css",
    "build-cleancss": "cleancss -o docs/assets/css/b-css.min.css docs/assets/css/b-css.css",
    "list-browser": "npx browserslist"
  },
  "browserslist": [
    "defaults",
    "last 2 versions"
  ],
  "dependencies": {
    "astro": "^1.7.2"
  },
  "devDependencies": {
    "autoprefixer": "^10.4.13",
    "clean-css-cli": "^5.6.1",
    "node-sass": "^8.0.0",
    "postcss-cli": "^10.1.0",
    "rimraf": "^3.0.2",
    "sass": "^1.56.2"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/victor-auffret/victor-auffret.github.io.git"
  },
  "author": "victor-auffret",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/victor-auffret/victor-auffret.github.io/issues"
  },
  "homepage": "https://github.com/victor-auffret/victor-auffret.github.io#readme"
}
